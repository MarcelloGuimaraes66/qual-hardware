server {
    listen 443 ssl http2;
    server_name qual-hardware.internal.aiquimist.ai;

    ssl_certificate     /etc/nginx/private-certs/qual-hardware.crt;
    ssl_certificate_key /etc/nginx/private-certs/qual-hardware.key;

    # Replace with the actual Aiquimist VPN and administration CIDRs.
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    deny all;

    client_max_body_size 2m;
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;

    location / {
        proxy_pass http://127.0.0.1:4178;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
