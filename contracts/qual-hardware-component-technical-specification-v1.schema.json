{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiquimist.ai/contracts/qual-hardware-component-technical-specification-v1.schema.json",
  "title": "Qual Hardware component technical specification 1.0",
  "type": "object",
  "required": ["schemaVersion", "componentId", "specificationVersion", "generatedAt", "fields", "completeness"],
  "properties": {
    "schemaVersion": { "const": "qual-hardware-component-technical-specification/1.0.0" },
    "componentId": { "type": "string", "minLength": 1 },
    "specificationVersion": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "labelPt", "valueType", "status", "required", "roles", "value", "confidence", "sourceEvidence"],
        "properties": {
          "code": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
          "labelPt": { "type": "string" },
          "valueType": { "enum": ["string", "number", "boolean"] },
          "status": { "enum": ["published", "not_published", "not_applicable", "ambiguous", "conflicting", "rejected"] },
          "required": { "type": "boolean" },
          "roles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "unit": { "type": ["string", "null"] },
          "originalLabel": { "type": ["string", "null"] },
          "originalValue": {},
          "confidence": { "enum": ["official", "derived_legacy", "unverified"] },
          "normalizationRule": { "type": ["string", "null"] },
          "sourceEvidence": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": false
      }
    },
    "completeness": {
      "type": "object",
      "required": ["requiredFieldCount", "publishedRequiredFieldCount", "missingRequiredFieldCodes", "conflictingFieldCodes", "percent", "complete", "procurementReady", "reasons"],
      "properties": {
        "requiredFieldCount": { "type": "integer", "minimum": 0 },
        "publishedRequiredFieldCount": { "type": "integer", "minimum": 0 },
        "percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "procurementReady": { "type": "boolean" },
        "missingRequiredFieldCodes": { "type": "array", "items": { "type": "string" } },
        "conflictingFieldCodes": { "type": "array", "items": { "type": "string" } }
        ,"complete": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
