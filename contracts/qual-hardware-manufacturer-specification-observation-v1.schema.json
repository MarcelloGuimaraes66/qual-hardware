{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiquimist.ai/contracts/qual-hardware-manufacturer-specification-observation-v1.schema.json",
  "title": "Observação oficial de especificação do fabricante 1.0",
  "type": "object",
  "required": ["schemaVersion", "id", "componentId", "manufacturer", "canonicalMpn", "scope", "subject", "fieldCode", "sectionCode", "sectionLabelPt", "displayOrder", "valueType", "originalLabel", "originalValue", "normalizedValue", "authority", "sourceId", "sourceUrl", "retrievedAt", "evidenceLocator", "rawArtifactSha256", "parserId", "parserVersion", "licensePolicy"],
  "properties": {
    "schemaVersion": { "const": "qual-hardware-manufacturer-specification-observation/1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "componentId": { "type": "string", "minLength": 1 },
    "manufacturer": { "type": "string", "minLength": 1 },
    "canonicalMpn": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["sku", "family", "architecture", "platform"] },
    "subject": { "type": "string", "minLength": 1 },
    "fieldCode": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
    "sectionCode": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
    "sectionLabelPt": { "type": "string", "minLength": 1 },
    "displayOrder": { "type": "integer", "minimum": 0 },
    "valueType": { "enum": ["string", "number", "boolean"] },
    "originalLabel": { "type": "string", "minLength": 1 },
    "originalValue": { "type": ["string", "number", "boolean", "null"] },
    "originalUnit": { "type": ["string", "null"] },
    "normalizedValue": { "type": ["string", "number", "boolean", "null"] },
    "normalizedUnit": { "type": ["string", "null"] },
    "authority": { "enum": ["official_sku", "official_family", "official_matrix", "secondary_reference"] },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "retrievedAt": { "type": "string", "format": "date-time" },
    "evidenceLocator": { "type": "string", "minLength": 1 },
    "rawArtifactSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "parserId": { "type": "string", "minLength": 1 },
    "parserVersion": { "type": "string", "minLength": 1 },
    "licensePolicy": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
