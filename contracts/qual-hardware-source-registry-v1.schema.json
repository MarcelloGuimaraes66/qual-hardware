{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MarcelloGuimaraes66/qual-hardware/contracts/qual-hardware-source-registry-v1.schema.json",
  "title": "qual-hardware-source-registry/1.0.0",
  "type": "object",
