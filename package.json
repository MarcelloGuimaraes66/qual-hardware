{
  "name": "@aiquimist/qual-hardware",
  "version": "0.1.0",
  "description": "Calculadora desktop de infraestrutura para cargas do Perceptrum",
  "author": "Aiquimist",
  "private": true,
  "type": "module",
  "main": "dist/server/desktop/main.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "npm run desktop:run",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "desktop:run": "npm run build && electron .",
    "desktop:package": "npm run build && electron-builder --publish never",
    "desktop:package:dir": "npm run build && electron-builder --dir --publish never",
    "desktop:smoke": "tsx scripts/smoke-desktop.ts",
    "start": "npm run desktop:run",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "catalog:collect": "tsx src/server/worker.ts --once",
    "catalog:publisher": "tsx scripts/catalog-publisher.ts",
    "catalog:qwen:detect": "tsx scripts/detect-qwen-model.ts",
    "catalog:sign": "tsx scripts/sign-catalog.ts",
    "evidence:sign": "tsx scripts/sign-evidence.ts",
    "db:schema": "tsx src/server/applySchema.ts",
    "audit:source": "tsx scripts/audit-source-inventory.ts",
    "reports:sample": "tsx scripts/generate-report-samples.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "hono": "^4.12.30",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
